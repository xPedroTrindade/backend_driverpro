MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/<banco>?retryWrites=true&w=majority
PORT=3000

# JWT
JWT_SECRET=gere_uma_chave_segura_com_node_-e_"require('crypto').randomBytes(64).toString('hex')"

# Firebase Admin SDK
# Gerar em: Firebase Console → Configurações → Contas de serviço → Gerar nova chave privada
FIREBASE_PROJECT_ID=driverpro-373d4
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@driverpro-373d4.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

